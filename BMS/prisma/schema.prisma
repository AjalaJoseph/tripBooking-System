// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js" // 🛠️ FIXED: Changed from "prisma-client" to valid "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id             String    @id @default(uuid())
  business_name  String
  business_email String?   @unique
  owner_name     String
  role            String @default("OWNER")
  password       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  staff    User[]
  products Product[]
  sales    Sale[]
  subscriptions  Subscription[]
  payments       Payment[]

  @@map("businesses")
}
enum SubscriptionPlanTier {
  FREE_TRIAL
  BASIC_PLAN
  PRO_PLAN
}
model Plan {
  id            String         @id @default(uuid())
  plan_name     SubscriptionPlanTier         @default(FREE_TRIAL) // e.g., "Free Trial", "Basic", "Premium"
  plan_price    Decimal        @db.Decimal(12, 2)
  max_staff     Int            // e.g., 2 for free trial
  max_sales     Int            @default(300)// e.g., 300 for free trial
  trial_days    Int            @default(30)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  subscriptions Subscription[]

  @@map("plans")
}

/// Tracks the active or past subscriptions of a business
model Subscription {
  id          String    @id @default(uuid())
  business_id String
  plan_id     String
  status      String    // "active", "expired", "cancelled"
  start_at    DateTime  @default(now())
  expired_at  DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  business    Business  @relation(fields: [business_id], references: [id], onDelete: Cascade)
  plan        Plan      @relation(fields: [plan_id], references: [id])
  payments    Payment[]

  @@map("subscriptions")
}

/// Records all monetary transactions for bookkeeping
model Payment {
  id              String       @id @default(uuid())
  business_id     String
  subscription_id String?
  amount          Decimal      @db.Decimal(12, 2)
  payment_status  String       // "success", "failed", "pending"
  reference       String       @unique // Gateway unique tracking ID
  paid_at         DateTime     @default(now())

  // Relations
  business        Business     @relation(fields: [business_id], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscription_id], references: [id], onDelete: SetNull)

  @@map("payments")
}
/// Staff members belonging to a business
model User {
  id           String   @id @default(uuid())
  businessId   String
  staff_name         String
  staff_email     String @unique
  password      String
  role         String   @default("STAFF")
  isPasswordChanged Boolean  @default(false) 
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales    Sale[]

  @@index([businessId])
  @@map("users")
}

/// Product catalog per business
model Product {
  id           String   @id @default(uuid())
  businessId   String
  product_name String
  sellingPrice Decimal  @db.Decimal(12, 2)
  stockCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleItems SaleItem[]

  // 🛠️ FIXED: Changed unique constraint to allow multiple different products in one business
  // @@unique([businessId, product_name]) 
  @@index([businessId, product_name])
  @@map("products")
}

/// Sales records for financial tracking
enum PaymentMethod {
  Cash
  POS
  TRANSFER
}
model Sale {
  id             String   @id @default(uuid())
  businessId     String
  userId         String // The staff relation link
  recorded_by    String // Name of staff for quick display
  payment_method PaymentMethod // e.g., "Cash", "POS", "Transfer"
  total_amount   Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id])
  items    SaleItem[] // Links to individual line items

  // Indexes optimized for date-filtered analytics (daily, weekly, monthly, yearly)
  @@index([businessId, createdAt])
  @@map("sales")
}

/// Individual items contained inside a specific sale
model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String? 
  productName String // Captures item name at moment of purchase
  quantity    Int
  unit_price  Decimal @db.Decimal(12, 2)
  total_price Decimal @db.Decimal(12, 2)

  // Relations
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}
